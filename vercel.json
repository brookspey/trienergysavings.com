{
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/florescent-tube-recycling.html",
      "destination": "/fluorescent-tube-recycling",
      "statusCode": 301
    },
    {
      "source": "/led-lightning.html",
      "destination": "/led-lighting",
      "statusCode": 301
    }
  ],
  "trailingSlash": false,
  "cleanUrls": true
}
